---
import { Image } from 'astro:assets';
import coachingImg from '../../assets/Julia-Blum-Personal-Training-Trainingseinblicke-Krafttraining-5.jpg';

const mainServices = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`,
    title: "Personal Training 1:1",
    description: "Vollständig auf dich zugeschnittene Einheiten – bei dir Zuhause oder im Freien. Wir arbeiten gemeinsam an deinen Zielen: Kraft, Ausdauer, Beweglichkeit oder einfach mehr Wohlbefinden im Alltag. Durch persönliche Anleitung, gezielte Übungen und kontinuierliche Technikkorrektur trainierst du effektiv und sicher.",
    features: ["Individuelle Trainingsgestaltung", "Technikkorrektur & Begleitung", "Trainingsfortschritt & Wohlbefinden"],
    price: "99 €",
    priceSub: "60 Min · 149 € für 90 Min",
    highlight: true,
    interesse: "personal-training",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
    title: "Online Personal Training",
    description: "Trainiere flexibel von Zuhause – profitiere von maximaler Flexibilität und effizienter Betreuung per Videocall. Jede Einheit wird individuell auf deine Ziele, dein Fitnesslevel und deine Möglichkeiten abgestimmt. Während des Trainings erhältst du direkte Technikkorrekturen, damit du die Übungen sicher und optimal ausführst.",
    features: ["Ortsunabhängigkeit", "Technikkorrektur", "Flexibilität"],
    price: "49 €",
    priceSub: "30 Min Session",
    highlight: false,
    interesse: "online-training",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    title: "Gruppentraining",
    description: "Perfekt für Gruppen – z.B. Freunde, Familie oder Kollegen. Trainiert zusammen, profitiert von professioneller Betreuung, motiviert euch gegenseitig und erreicht eure Ziele gemeinsam. Die Einheiten werden auf eure Gruppe abgestimmt, sodass jeder auf seinem individuellen Fitnesslevel trainieren kann.",
    features: ["2–5 Personen", "Für alle Fitnesslevel", "Gegenseitige Motivation"],
    price: "Auf Anfrage",
    priceSub: "Aktuelle Kurszeiten erfragen",
    highlight: false,
    interesse: "gruppentraining",
  },
];

const specialServices = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`,
    title: "Teen Training",
    description: "Speziell für Jugendliche ab 14 Jahren. Sicheres, altersgerechtes Training, das Spaß macht und die richtigen Grundlagen für ein aktives Leben legt.",
    price: "90 €",
    priceSub: "60 Min",
    interesse: "teen-training",
    href: null,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
    title: "Prä- & Postnataltraining",
    description: "Einfühlsames Training während und nach der Schwangerschaft. Ich begleite dich sicher durch diese besondere Zeit – abgestimmt auf deinen Körper und deine Bedürfnisse. Auch in Kleingruppen möglich.",
    price: "Auf Anfrage",
    priceSub: "Individuelle Planung",
    interesse: "praenatal",
    href: null,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
    title: "Krankenkassenzertifizierte Kurse",
    description: "Nach den Qualitätsstandards der gesetzlichen Krankenkassen anerkannte Kurse. Sie sind gezielt darauf ausgerichtet, Gesundheit, Beweglichkeit und langfristige Fitness zu fördern und dich dabei zu unterstützen, aktiv und gesund zu bleiben.",
    price: "Wechselnde Kursangebote",
    priceSub: "Bezuschussung möglich",
    interesse: "krankenkassenkurse",
    href: `${import.meta.env.BASE_URL}/kurse`,
  },
];
---

<section id="angebote" class="relative z-[4] -mb-20 py-24 px-5 bg-white">
  <div class="mx-auto max-w-6xl">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-10">
      <p class="text-brand-500 text-sm font-semibold uppercase tracking-widest mb-4">
        Meine Angebote
      </p>
      <h2
        class="text-4xl md:text-5xl text-stone-900 mb-4 leading-tight"
      >
        Training, das zu Dir passt
      </h2>
      <p class="text-stone-500 text-base leading-relaxed">
        Jedes Programm beginnt mit einem kostenlosen und unverbindlichen Erstgespräch.
      </p>
    </div>

    <!-- Main 3 cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-6">
      {mainServices.map((s) => (
        <div
          class:list={[
            "rounded-2xl p-7 flex flex-col gap-4 transition-shadow hover:shadow-xl",
            s.highlight
              ? "bg-brand-500 text-white shadow-lg"
              : "bg-brand-50 border border-brand-100",
          ]}
        >
          <span
            class:list={["[&>svg]:inline", s.highlight ? "text-brand-200" : "text-brand-500"]}
            set:html={s.icon}
          />
          <h3
            class:list={["text-xl font-semibold leading-snug", s.highlight ? "text-white" : "text-stone-900"]}
          >
            {s.title}
          </h3>
          <p class:list={["text-sm leading-relaxed flex-1", s.highlight ? "text-white/80" : "text-stone-600"]}>
            {s.description}
          </p>
          <ul class="space-y-2">
            {s.features.map((f) => (
              <li class:list={["flex items-center gap-2 text-sm", s.highlight ? "text-white/90" : "text-stone-700"]}>
                <svg class="w-4 h-4 shrink-0" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-opacity="0.35" />
                  <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <!-- Price -->
          <div
            class:list={[
              "mt-2 pt-4 border-t",
              s.highlight ? "border-white/20" : "border-brand-200",
            ]}
          >
            <p class:list={["text-2xl font-bold", s.highlight ? "text-white" : "text-brand-600"]}>
              {s.price}
            </p>
            <p class:list={["text-xs mt-0.5", s.highlight ? "text-white/60" : "text-stone-400"]}>
              {s.priceSub}
            </p>
          </div>
          <a
            href="#kontakt"
            data-interesse={s.interesse}
            class:list={[
              "inline-block text-center text-sm font-semibold px-5 py-3 rounded-full transition-colors",
              s.highlight
                ? "bg-white text-brand-600 hover:bg-brand-50"
                : "bg-brand-500 text-white hover:bg-brand-600",
            ]}
          >
            Jetzt anfragen
          </a>
        </div>
      ))}
    </div>

    <!-- Mobile-only toggle button -->
    <div class="flex justify-center mb-6 md:hidden">
      <button
        id="toggle-secondary"
        class="flex items-center gap-2 text-sm font-semibold text-brand-600 border border-brand-300 rounded-full px-5 py-2.5 hover:bg-brand-50 transition-colors"
        aria-expanded="false"
        aria-controls="secondary-services"
      >
        <span id="toggle-label">Weitere Angebote anzeigen</span>
        <svg id="toggle-icon" class="w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>

    <!-- Secondary 3 cards -->
    <div id="secondary-services" class="hidden md:grid sm:grid-cols-2 md:grid-cols-3 gap-4 mb-10">
      {specialServices.map((s) => (
        <div class="bg-brand-50 rounded-2xl p-6 border border-brand-100 flex flex-col gap-3 hover:shadow-lg transition-shadow">
          <span class="text-brand-500 [&>svg]:inline" set:html={s.icon} />
          <h3 class="text-base font-semibold text-stone-900">{s.title}</h3>
          <p class="text-sm text-stone-500 leading-relaxed flex-1">{s.description}</p>
          <div class="pt-3 border-t border-brand-200 flex flex-col gap-2.5">
            <div>
              <p class="text-lg font-bold text-brand-600">{s.price}</p>
              <p class="text-xs text-stone-400">{s.priceSub}</p>
            </div>
            {s.href ? (
              <a
                href={s.href}
                class="block text-center text-sm font-semibold px-5 py-2.5 rounded-full bg-brand-500 text-white hover:bg-brand-600 transition-colors"
              >
                Kursdetails ansehen →
              </a>
            ) : (
              <a
                href="#kontakt"
                data-interesse={s.interesse}
                class="block text-center text-sm font-semibold px-5 py-2.5 rounded-full bg-brand-500 text-white hover:bg-brand-600 transition-colors"
              >
                Jetzt anfragen
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- BGM teaser (subpage placeholder) -->
    <div class="relative overflow-hidden rounded-2xl bg-brand-900 text-white">
      <div class="absolute inset-0 opacity-20">
        <Image
          src={coachingImg}
          alt=""
          class="w-full h-full object-cover object-top"
          widths={[800]}
          sizes="100vw"
        />
      </div>
      <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6 px-8 py-10">
        <div>
          <p class="text-brand-300 text-xs font-semibold uppercase tracking-widest mb-2">
            Für Unternehmen
          </p>
          <h3 class="text-2xl font-bold mb-2">
            Betriebliches Gesundheitsmanagement
          </h3>
          <p class="text-white/70 text-sm max-w-lg leading-relaxed">
            Gesunde, motivierte Mitarbeitende sind der Kern eines erfolgreichen Unternehmens. Ich entwickle mit euch maßgeschneiderte BGM-Programme – von Bewegungspausen bis zu Gesundheitstagen.
          </p>
        </div>
        <a
          href={`${import.meta.env.BASE_URL}/bgm`}
          class="shrink-0 inline-block bg-brand-300 hover:bg-brand-200 text-brand-900 font-semibold px-7 py-3.5 rounded-full text-sm transition-colors whitespace-nowrap"
        >
          Mehr erfahren →
        </a>
      </div>
    </div>

    <p class="text-center text-xs text-stone-400 mt-6">
      Alle Preise zzgl. MwSt.
    </p>
  </div>

  <!-- Diagonal divider → brand-50 wedge pointing into About -->
  <div class="absolute bottom-0 inset-x-0 h-20 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-full">
      <path d="M 0,80 L 0,68 C 360,58 720,72 1080,64 C 1260,60 1360,70 1440,66 L 1440,80 Z" fill="#f2f7e8" />
    </svg>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[data-interesse]').forEach((link) => {
    link.addEventListener('click', () => {
      const val = link.dataset.interesse;
      const select = document.getElementById('interesse') as HTMLSelectElement | null;
      if (select && val) select.value = val;
    });
  });

  const toggleBtn = document.getElementById('toggle-secondary');
  const secondaryGrid = document.getElementById('secondary-services');
  const toggleLabel = document.getElementById('toggle-label');
  const toggleIcon = document.getElementById('toggle-icon');

  toggleBtn?.addEventListener('click', () => {
    const isHidden = secondaryGrid?.classList.contains('hidden');
    if (isHidden) {
      secondaryGrid?.classList.remove('hidden');
      secondaryGrid?.classList.add('grid');
      if (toggleLabel) toggleLabel.textContent = 'Weniger anzeigen';
      toggleIcon?.classList.add('rotate-180');
      toggleBtn.setAttribute('aria-expanded', 'true');
    } else {
      secondaryGrid?.classList.add('hidden');
      secondaryGrid?.classList.remove('grid');
      if (toggleLabel) toggleLabel.textContent = 'Weitere Angebote anzeigen';
      toggleIcon?.classList.remove('rotate-180');
      toggleBtn.setAttribute('aria-expanded', 'false');
    }
  });
</script>

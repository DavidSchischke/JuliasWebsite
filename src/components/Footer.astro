---
import { Image } from 'astro:assets';
import logo from '../../assets/Logo-Julia-Blum-Personal-Training_500-1.png';

const year = new Date().getFullYear();
---

<footer class="bg-brand-900 text-white pt-14 pb-8 px-5">
  <div class="mx-auto max-w-6xl">
    <!-- Top row -->
    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-8 pb-10 border-b border-white/10">
      <!-- Logo + tagline -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <Image
          src={logo}
          alt="Julia Blum Personal Training"
          height={44}
          class="h-11 w-auto brightness-0 invert"
        />
        <p class="text-white/50 text-sm">Personal Training · Köln Lindenthal</p>
      </div>

      <!-- BGM link -->
      <div class="text-center md:text-left">
        <p class="text-white/30 text-xs uppercase tracking-widest mb-2">Für Unternehmen</p>
        <a href={`${import.meta.env.BASE_URL}/bgm`} class="text-white/70 hover:text-white text-sm transition-colors">
          Betriebliches Gesundheitsmanagement →
        </a>
      </div>

      <!-- Social -->
      <div class="flex items-center gap-3">
        <a
          href="https://www.instagram.com/juliablum_personaltraining"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Julia Blum auf Instagram"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="1.5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" stroke-width="1.5"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/40">
      <p>&copy; {year} Julia Blum Personal Training. Alle Rechte vorbehalten.</p>
      <div class="flex items-center gap-5">
        <a href="/impressum" class="hover:text-white/70 transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-white/70 transition-colors">Datenschutzerklärung</a>
      </div>
    </div>
  </div>
</footer>

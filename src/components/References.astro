---
const clients = [
  "Deutsche Sporthochschule Köln",
  "UniSport der Universität zu Köln",
  "Schauspiel Köln",
  "SoCura Köln",
  "Württembergische Versicherung Köln",
  "IBM Köln",
];
---

<section class="relative z-0 py-16 px-5 bg-brand-50 border-t border-brand-100">
  <div class="mx-auto max-w-6xl">
    <p class="text-center text-brand-500 text-sm font-semibold uppercase tracking-widest mb-3">
      Referenzen
    </p>
    <p class="text-center text-stone-500 text-sm mb-10 max-w-lg mx-auto leading-relaxed">
      Unternehmen und Institutionen, die ich bereits im Betrieblichen Gesundheitsmanagement begleiten durfte.
    </p>
    <div class="flex flex-wrap justify-center gap-3 md:gap-4">
      {clients.map((client) => (
        <div class="flex items-center gap-2.5 bg-white border border-brand-100 rounded-full px-5 py-2.5 shadow-sm">
          <svg class="w-3 h-3 shrink-0 text-brand-400 fill-current" viewBox="0 0 8 8">
            <circle cx="4" cy="4" r="4"/>
          </svg>
          <span class="text-sm font-medium text-stone-700 whitespace-nowrap">{client}</span>
        </div>
      ))}
    </div>
  </div>
</section>

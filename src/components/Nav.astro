---
import { Image } from 'astro:assets';
import logo from '../../assets/Logo-Julia-Blum-Personal-Training_500-1.png';

const links = [
  { label: "Angebote",   href: "#angebote" },
  { label: "Über mich",  href: "#ueber-mich" },
  { label: "Kontakt",    href: "#kontakt" },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-brand-100 transition-shadow duration-300"
>
  <div class="mx-auto max-w-6xl px-5 py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" aria-label="Julia Blum Personal Training – zur Startseite">
      <Image
        src={logo}
        alt="Julia Blum Personal Training"
        height={48}
        class="h-12 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-stone-600 hover:text-brand-500 text-sm font-medium transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#kontakt"
        class="bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors"
      >
        Erstgespräch buchen
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      aria-label="Menü öffnen"
      aria-expanded="false"
      class="md:hidden text-stone-700 p-1"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-brand-100 bg-brand-50 px-5 pb-6 pt-4 flex flex-col gap-4"
  >
    {links.map((link) => (
      <a
        href={link.href}
        class="text-stone-700 hover:text-brand-500 text-base font-medium transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a
      href="#kontakt"
      class="mt-2 inline-block text-center bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold px-5 py-3 rounded-full transition-colors"
    >
      Erstgespräch buchen
    </a>
  </div>
</header>

<script>
  const nav = document.getElementById("nav")!;
  const menuBtn = document.getElementById("menu-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const iconOpen = document.getElementById("icon-open")!;
  const iconClose = document.getElementById("icon-close")!;

  window.addEventListener("scroll", () => {
    nav.classList.toggle("shadow-md", window.scrollY > 10);
  });

  menuBtn.addEventListener("click", () => {
    const isOpen = !mobileMenu.classList.contains("hidden");
    mobileMenu.classList.toggle("hidden", isOpen);
    iconOpen.classList.toggle("hidden", !isOpen);
    iconClose.classList.toggle("hidden", isOpen);
    menuBtn.setAttribute("aria-expanded", String(!isOpen));
    menuBtn.setAttribute("aria-label", isOpen ? "Menü öffnen" : "Menü schließen");
  });

  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      iconOpen.classList.remove("hidden");
      iconClose.classList.add("hidden");
      menuBtn.setAttribute("aria-expanded", "false");
      menuBtn.setAttribute("aria-label", "Menü öffnen");
    });
  });
</script>

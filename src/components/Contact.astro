---
---

<section id="kontakt" class="py-24 px-5 bg-white">
  <div class="mx-auto max-w-6xl">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Left: info -->
      <div>
        <p class="text-brand-500 text-sm font-semibold uppercase tracking-widest mb-4">
          Kontakt
        </p>
        <h2
          class="text-4xl md:text-5xl text-stone-900 mb-6 leading-tight"
          style="font-family: 'Playfair Display', Georgia, serif;"
        >
          Bereit für deinen<br />ersten Schritt?
        </h2>
        <p class="text-stone-500 text-base leading-relaxed mb-8">
          Schreib mir eine Nachricht – ein kostenloses, unverbindliches Erstgespräch ist immer der beste Anfang. Ich melde mich innerhalb von 24 Stunden bei dir.
        </p>

        <ul class="space-y-4">
          <li class="flex items-center gap-4">
            <span class="w-10 h-10 rounded-full bg-brand-100 flex items-center justify-center text-brand-600 shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </span>
            <a href="mailto:hello@juliablum-personaltraining.de" class="text-stone-700 text-sm hover:text-brand-600 transition-colors">
              hello@juliablum-personaltraining.de
            </a>
          </li>
          <li class="flex items-center gap-4">
            <span class="w-10 h-10 rounded-full bg-brand-100 flex items-center justify-center text-brand-600 shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </span>
            <span class="text-stone-700 text-sm">Köln Lindenthal</span>
          </li>
          <li class="flex items-center gap-4">
            <span class="w-10 h-10 rounded-full bg-brand-100 flex items-center justify-center text-brand-600 shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="1.5"/>
                <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" stroke-width="1.5"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </span>
            <a
              href="https://www.instagram.com/juliablum_personaltraining"
              target="_blank"
              rel="noopener noreferrer"
              class="text-stone-700 text-sm hover:text-brand-600 transition-colors"
            >
              @juliablum_personaltraining
            </a>
          </li>
        </ul>
      </div>

      <!-- Right: form -->
      <div class="bg-brand-50 rounded-2xl p-8 border border-brand-100">
        <!--
          Spam protection:
          1. Honeypot field (bot-field) — hidden from humans, filled by bots
          2. Load timestamp (form-time) — JS rejects submits < 3s after page load
          3. data-netlify attributes for server-side filtering on Netlify hosting
        -->
        <form
          id="contact-form"
          class="space-y-5"
          name="kontakt"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          novalidate
        >
          <!-- Honeypot (hidden from real users) -->
          <div aria-hidden="true" class="absolute -left-[9999px] opacity-0 pointer-events-none" tabindex="-1">
            <label>Nicht ausfüllen <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </div>
          <!-- Timestamp (filled by JS on page load) -->
          <input type="hidden" id="form-time" name="form-time" value="" />

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium text-stone-700 mb-1.5">
                Dein Name <span class="text-brand-500">*</span>
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder="Julia Muster"
                class="w-full rounded-xl border border-brand-200 bg-white px-4 py-3 text-sm text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-stone-700 mb-1.5">
                E-Mail-Adresse <span class="text-brand-500">*</span>
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="julia@beispiel.de"
                class="w-full rounded-xl border border-brand-200 bg-white px-4 py-3 text-sm text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition"
              />
            </div>
          </div>

          <div>
            <label for="interesse" class="block text-sm font-medium text-stone-700 mb-1.5">
              Worum geht es dir?
            </label>
            <select
              id="interesse"
              name="interesse"
              class="w-full rounded-xl border border-brand-200 bg-white px-4 py-3 text-sm text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition"
            >
              <option value="">Bitte wählen…</option>
              <option value="personal-training">Personal Training 1:1</option>
              <option value="online-training">Online Personal Training</option>
              <option value="gruppentraining">Gruppentraining</option>
              <option value="teen-training">Teen Training</option>
              <option value="praenatal">Prä- & Postnataltraining</option>
              <option value="ruecken">Rückenfit-Kurs</option>
              <option value="bgm">Betriebliches Gesundheitsmanagement</option>
              <option value="sonstiges">Sonstiges</option>
            </select>
          </div>

          <div>
            <label for="nachricht" class="block text-sm font-medium text-stone-700 mb-1.5">
              Deine Nachricht
            </label>
            <textarea
              id="nachricht"
              name="nachricht"
              rows="4"
              placeholder="Erzähl mir ein bisschen von dir, deinen Zielen oder deinem Alltag – alles, was du für wichtig hältst…"
              class="w-full rounded-xl border border-brand-200 bg-white px-4 py-3 text-sm text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent transition resize-none"
            ></textarea>
          </div>

          <!-- Data privacy consent -->
          <div>
            <label class="flex items-start gap-3 cursor-pointer">
              <input
                type="checkbox"
                id="datenschutz"
                name="datenschutz"
                required
                class="mt-0.5 w-4 h-4 shrink-0 rounded border-brand-300 text-brand-500 focus:ring-brand-400 cursor-pointer accent-brand-500"
              />
              <span class="text-sm text-stone-600 leading-relaxed">
                Ich habe die <a href="/datenschutz" target="_blank" class="text-brand-600 underline underline-offset-2 hover:text-brand-500 transition-colors">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung meiner Anfrage zu. <span class="text-brand-500">*</span>
              </span>
            </label>
          </div>

          <!-- Error / success messages -->
          <div id="form-error" class="hidden rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700"></div>
          <div id="form-success" class="hidden rounded-xl bg-brand-100 border border-brand-200 px-4 py-3 text-sm text-brand-800 font-medium">
            Vielen Dank für deine Nachricht! Ich melde mich bald bei dir.
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-brand-500 hover:bg-brand-600 text-white font-semibold py-4 rounded-xl text-sm transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
          >
            Nachricht senden
          </button>

          <p class="text-center text-xs text-stone-400">
            Ich antworte innerhalb von 24 Stunden · Kein Spam, versprochen.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const timeField = document.getElementById("form-time") as HTMLInputElement | null;
  if (timeField) timeField.value = String(Date.now());

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const errorBox = document.getElementById("form-error")!;
  const successBox = document.getElementById("form-success")!;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorBox.classList.add("hidden");
    errorBox.textContent = "";

    const data = new FormData(form);

    // Honeypot check
    if (data.get("bot-field")) return;

    // Timing check — reject if submitted in under 3 seconds
    const loadTime = parseInt(String(data.get("form-time") ?? "0"), 10);
    if (Date.now() - loadTime < 3000) return;

    // Basic validation
    const name = String(data.get("name") ?? "").trim();
    const email = String(data.get("email") ?? "").trim();
    if (!name || !email) {
      errorBox.textContent = "Bitte Name und E-Mail-Adresse ausfüllen.";
      errorBox.classList.remove("hidden");
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorBox.textContent = "Bitte eine gültige E-Mail-Adresse eingeben.";
      errorBox.classList.remove("hidden");
      return;
    }
    if (!data.get("datenschutz")) {
      errorBox.textContent = "Bitte akzeptiere die Datenschutzerklärung, um fortzufahren.";
      errorBox.classList.remove("hidden");
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Wird gesendet…";
    }

    try {
      const res = await fetch(form.action || "/", {
        method: "POST",
        headers: { "Accept": "application/json" },
        body: data,
      });

      if (res.ok) {
        form.reset();
        if (timeField) timeField.value = String(Date.now());
        successBox.classList.remove("hidden");
        if (submitBtn) submitBtn.classList.add("hidden");
      } else {
        throw new Error("server");
      }
    } catch {
      errorBox.textContent = "Etwas ist schiefgelaufen. Bitte schreib mir direkt an hello@juliablum-personaltraining.de.";
      errorBox.classList.remove("hidden");
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Nachricht senden";
      }
    }
  });
</script>

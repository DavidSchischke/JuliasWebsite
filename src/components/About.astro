---
import { Image } from 'astro:assets';
import consultingImg from '../../assets/Trainingseinblicke-Julia-Blum-Personal-Training-Koeln-5.jpg';

const studium = [
  "B.A. Sport- und Bewegungsvermittlung im Freizeit- und Breitensport, Deutsche Sporthochschule Köln",
];

const zertifikate = [
  "Fitnesstrainer A-Lizenz",
  "Fitnesstrainer B-Lizenz",
  "DOSB Übungsleiter-C-Lizenz",
  "Prä- und Postnatale Fitnesstrainerin (superMAMAfitness)",
  "Sportmassage",
  "DLRG Rettungsschwimmer Abzeichen (Silber)",
];

const weiterbildungen = [
  "Pilates Instructor",
  "Kinesiologisches Taping",
  "Mentalcoaching",
  "Sport und Ernährung",
  "Recovery Expert",
  "Functional Training – Rehabilitation",
  "Functional Training – Koordination & Flexibilität",
];

const values = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`,
    title: "Individuell",
    text: "Kein Mensch ist wie der andere. Deshalb gibt es bei mir keine Einheitsprogramme – nur Pläne, die wirklich zu dir passen.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
    title: "Einfühlsam",
    text: "Ich höre zu, bevor ich trainiere. Dein Tempo, deine Geschichte und deine Grenzen sind der Ausgangspunkt für alles.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    title: "Nachhaltig",
    text: "Schnelle Erfolge interessieren mich weniger als langfristige Veränderung. Wir bauen Gewohnheiten, die bleiben.",
  },
];
---

<section id="ueber-mich" class="relative z-[3] -mb-20 py-24 px-5 bg-brand-50">
  <div class="mx-auto max-w-6xl">
    <!-- Top: 2-col bio -->
    <div class="grid md:grid-cols-2 gap-14 items-center mb-14">
      <!-- Photo -->
      <div class="relative">
        <div class="rounded-2xl overflow-hidden aspect-[4/3] shadow-md">
          <Image
            src={consultingImg}
            alt="Julia Blum im Gespräch mit einer Kundin auf einer Trainingsmatte im Park"
            class="w-full h-full object-cover object-center"
            widths={[600, 900]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
      </div>

      <!-- Text -->
      <div>
        <p class="text-brand-500 text-sm font-semibold uppercase tracking-widest mb-4">
          Über mich
        </p>
        <h2
          class="text-4xl md:text-5xl text-stone-900 mb-6 leading-tight"
        >
          Meine Trainingsphilosophie
        </h2>
        <div class="space-y-4 text-stone-600 text-base leading-relaxed">
          <p>
            Personal Training ist für mich etwas ganz Besonderes: individuell, persönlich und die bestmögliche Unterstützung auf dem Weg zu Deinem Ziel. Jedes Training wird individuell auf Deine Bedürfnisse und Dein Fitnesslevel abgestimmt.
          </p>
          <p>
            Mir ist dabei besonders wichtig zu zeigen, dass Bewegung und Sport Spaß machen und uns körperlich wie mental stärken. Gemeinsam definieren wir Dein persönliches Ziel und arbeiten Schritt für Schritt daran.
          </p>
        </div>
      </div>
    </div>

    <!-- Values row -->
    <div class="grid sm:grid-cols-3 gap-6 mb-14">
      {values.map((v) => (
        <div class="bg-white rounded-2xl p-7 border border-brand-100 shadow-sm">
          <div class="w-11 h-11 rounded-xl bg-brand-500 text-white flex items-center justify-center mb-4" set:html={v.icon} />
          <h3 class="text-base font-semibold text-stone-900 mb-2">{v.title}</h3>
          <p class="text-sm text-stone-500 leading-relaxed">{v.text}</p>
        </div>
      ))}
    </div>

    <!-- Qualifications: 3 columns -->
    <div>
      <p class="text-brand-500 text-sm font-semibold uppercase tracking-widest mb-6 text-center">
        Qualifikationen
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Studium -->
        <div class="bg-white rounded-2xl p-7 border border-brand-100 shadow-sm">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-9 h-9 rounded-lg bg-brand-500 text-white flex items-center justify-center shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
              </svg>
            </div>
            <h3 class="text-base font-semibold text-stone-900">Studium</h3>
          </div>
          <ul class="space-y-3">
            {studium.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-stone-600 leading-relaxed">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-brand-400 fill-current" viewBox="0 0 16 16">
                  <path fill-rule="evenodd" d="M8 1a7 7 0 100 14A7 7 0 008 1zm3.28 5.28a.75.75 0 00-1.06-1.06L7 8.44 5.78 7.22a.75.75 0 00-1.06 1.06l1.75 1.75a.75.75 0 001.06 0l3.75-3.75z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Zertifikate -->
        <div class="bg-white rounded-2xl p-7 border border-brand-100 shadow-sm">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-9 h-9 rounded-lg bg-brand-500 text-white flex items-center justify-center shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <h3 class="text-base font-semibold text-stone-900">Zertifikate</h3>
          </div>
          <ul class="space-y-3">
            {zertifikate.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-stone-600 leading-relaxed">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-brand-400 fill-current" viewBox="0 0 16 16">
                  <path fill-rule="evenodd" d="M8 1a7 7 0 100 14A7 7 0 008 1zm3.28 5.28a.75.75 0 00-1.06-1.06L7 8.44 5.78 7.22a.75.75 0 00-1.06 1.06l1.75 1.75a.75.75 0 001.06 0l3.75-3.75z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Weiterbildungen -->
        <div class="bg-white rounded-2xl p-7 border border-brand-100 shadow-sm">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-9 h-9 rounded-lg bg-brand-500 text-white flex items-center justify-center shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-base font-semibold text-stone-900">Weiterbildungen</h3>
          </div>
          <ul class="space-y-3">
            {weiterbildungen.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-stone-600 leading-relaxed">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-brand-400 fill-current" viewBox="0 0 16 16">
                  <path fill-rule="evenodd" d="M8 1a7 7 0 100 14A7 7 0 008 1zm3.28 5.28a.75.75 0 00-1.06-1.06L7 8.44 5.78 7.22a.75.75 0 00-1.06 1.06l1.75 1.75a.75.75 0 001.06 0l3.75-3.75z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Diagonal divider → white wedge pointing into Gallery -->
  <div class="absolute bottom-0 inset-x-0 h-20 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-full">
      <path d="M 0,80 C 240,70 480,60 720,67 C 960,74 1200,62 1440,67 L 1440,80 Z" fill="white" />
    </svg>
  </div>
</section>

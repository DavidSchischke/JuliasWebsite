---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Krankenkassenzertifizierte Kurse | Julia Blum Personal Training"
  description="Krankenkassenzertifizierte Präventionskurse von Julia Blum in Köln. Qualitätsgeprüfte Kurse nach den Standards der gesetzlichen Krankenkassen – Bezuschussung möglich."
>
  <Nav />

  <main class="min-h-screen flex flex-col bg-brand-50 pt-[72px]">
    <section class="px-5 py-20">
      <div class="mx-auto max-w-4xl">

        <p class="text-brand-500 text-sm font-semibold uppercase tracking-widest mb-5">
          Meine Angebote
        </p>

        <h1 class="text-stone-900 text-4xl sm:text-5xl leading-[1.1] mb-6">
          Krankenkassenzertifizierte Kurse
        </h1>

        <p class="text-stone-600 text-lg leading-relaxed mb-4">
          Nach den Qualitätsstandards der gesetzlichen Krankenkassen anerkannte Kurse. Sie sind gezielt darauf ausgerichtet, Gesundheit, Beweglichkeit und langfristige Fitness zu fördern und dich dabei zu unterstützen, aktiv und gesund zu bleiben.
        </p>
        <p class="text-stone-500 text-base leading-relaxed mb-10">
          Viele gesetzliche Krankenkassen bezuschussen zertifizierte Präventionskurse. Frag einfach bei deiner Krankenkasse nach – die Kostenübernahme ist in der Regel unkompliziert.
        </p>

        <!-- Info badges — centered -->
        <div class="flex flex-wrap justify-center gap-3 mb-14">
          {[
            "ZPP-zertifiziert",
            "Bezuschussung durch Krankenkasse möglich",
            "Kleine Gruppengrößen",
          ].map((badge) => (
            <span class="inline-flex items-center gap-2 text-sm font-medium text-brand-700 bg-white border border-brand-200 px-4 py-2 rounded-full shadow-sm">
              <svg class="w-3 h-3 shrink-0 text-brand-400 fill-current" viewBox="0 0 8 8">
                <circle cx="4" cy="4" r="4"/>
              </svg>
              {badge}
            </span>
          ))}
        </div>

        <!-- Aktuelle Kursangebote placeholder -->
        <div class="bg-white rounded-2xl border border-brand-100 shadow-sm p-8 mb-8 text-center">
          <svg class="w-10 h-10 text-brand-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <h2 class="text-xl font-semibold text-stone-900 mb-2">Aktuelle Kursangebote</h2>
          <p class="text-stone-500 text-sm leading-relaxed max-w-md mx-auto mb-6">
            Die aktuellen Kurszeiten und freien Plätze teile ich gerne direkt mit dir. Schreib mir einfach – ich melde mich schnell bei dir.
          </p>
          <a
            href={`${import.meta.env.BASE_URL}/?interesse=krankenkassenkurse#kontakt`}
            class="inline-block bg-brand-500 hover:bg-brand-600 text-white font-semibold px-7 py-3.5 rounded-full text-sm transition-colors shadow-sm"
          >
            Kurszeiten anfragen
          </a>
        </div>

        <a
          href={`${import.meta.env.BASE_URL}/#angebote`}
          class="inline-block text-brand-600 hover:text-brand-500 font-medium text-sm transition-colors"
        >
          ← Alle Angebote ansehen
        </a>

      </div>
    </section>
  </main>

  <Footer />
</Layout>
